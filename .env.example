# LiveKit Configuration
# WebSocket URL for LiveKit cloud connection
VITE_LIVEKIT_URL=wss://webagent-revamp-brx4ajqj.livekit.cloud

# Backend API Configuration (webBackendCors Flask server)
# Production: https://web.afterlife.org.in
# Local development: http://localhost:5001
VITE_BACKEND_URL=https://web.afterlife.org.in

# Calling Agent Backend URL (calling_server.py)
# Production: https://call.afterlife.org.in
# Local development: http://localhost:5002
VITE_CALLING_BACKEND_URL=https://call.afterlife.org.in

# WhatsApp Agent Backend URL
# Production: https://wa.afterlife.org.in
VITE_WHATSAPP_BACKEND_URL=https://wa.afterlife.org.in

# Auth API (legacy Node.js backend)
# Production: https://g1wymxzrle.execute-api.eu-west-3.amazonaws.com/api/auth
# Local development: http://localhost:5000/api/auth
VITE_AUTH_API=https://g1wymxzrle.execute-api.eu-west-3.amazonaws.com/api/auth

# Google OAuth
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Note: All environment variables in Vite must be prefixed with VITE_
# These variables are embedded into the client bundle at build time
